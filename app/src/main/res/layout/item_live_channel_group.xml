<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="6mm"
    android:layout_marginTop="4mm"
    android:layout_marginRight="6mm"
    android:layout_marginBottom="4mm"
    android:background="@drawable/shape_live_focus"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvChannelGroupName"
        android:layout_width="0mm"
        android:layout_height="52mm"
        android:layout_weight="1"
        android:ellipsize="marquee"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:textColor="@color/ui_text_primary"
        android:textSize="20mm" />
</LinearLayout>
