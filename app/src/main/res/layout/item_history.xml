<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/poster_card_item_margin"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/mItemFrame"
        android:layout_width="@dimen/poster_card_width"
        android:layout_height="@dimen/poster_card_height"
        android:background="@drawable/shape_poster_card_focus"
        android:clipChildren="true"
        android:clipToOutline="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:duplicateParentState="true">

        <ImageView
            android:id="@+id/ivThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/vs_8"
            android:layout_marginTop="@dimen/vs_8"
            android:layout_marginRight="@dimen/vs_8"
            android:background="@drawable/shape_history_source_badge"
            android:ellipsize="end"
            android:gravity="center"
            android:maxWidth="@dimen/poster_card_width"
            android:paddingLeft="@dimen/vs_10"
            android:paddingTop="@dimen/vs_4"
            android:paddingRight="@dimen/vs_10"
            android:paddingBottom="@dimen/vs_4"
            android:singleLine="true"
            android:textColor="@color/ui_accent_bright"
            android:textSize="@dimen/ts_16" />

        <TextView
            android:id="@+id/tvNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/shape_poster_progress_strip"
            android:ellipsize="end"
            android:gravity="center"
            android:paddingLeft="@dimen/vs_8"
            android:paddingTop="@dimen/vs_8"
            android:paddingRight="@dimen/vs_8"
            android:paddingBottom="@dimen/vs_10"
            android:singleLine="true"
            android:textColor="@color/ui_text_secondary"
            android:textSize="@dimen/ts_16"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/delFrameLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_user_delete"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="@dimen/vs_80"
                android:layout_height="@dimen/vs_80"
                android:layout_gravity="center"
                android:src="@drawable/icon_delete"
                android:tint="@color/ui_accent_bright" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvName"
        android:layout_width="@dimen/poster_card_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/vs_8"
        android:ellipsize="marquee"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="@color/ui_text_primary"
        android:textSize="@dimen/ts_22" />
</LinearLayout>
