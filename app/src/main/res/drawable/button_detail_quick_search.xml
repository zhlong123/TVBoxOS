<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="20mm" />
            <solid android:color="#99E8A838" />
            <stroke
                android:width="2mm"
                android:color="@color/ui_stroke_focus" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="20mm" />
            <solid android:color="#80151A22" />
            <stroke
                android:width="1mm"
                android:color="@color/ui_stroke_subtle" />
        </shape>
    </item>
</selector>
