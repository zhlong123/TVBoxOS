<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/preview_player_radius" />
            <stroke
                android:width="2.5mm"
                android:color="@color/ui_stroke_focus" />
            <solid android:color="#CC0A0C10" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/preview_player_radius" />
            <stroke
                android:width="1mm"
                android:color="#22FFFFFF" />
            <solid android:color="#990A0C10" />
        </shape>
    </item>
</selector>
