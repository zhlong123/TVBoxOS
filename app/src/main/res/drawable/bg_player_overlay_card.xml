<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="18mm" />
            <solid android:color="#CC151A22" />
            <stroke
                android:width="1mm"
                android:color="#22FFFFFF" />
        </shape>
    </item>
    <item android:gravity="top">
        <shape>
            <corners
                android:topLeftRadius="18mm"
                android:topRightRadius="18mm" />
            <size android:height="2mm" />
            <gradient
                android:angle="0"
                android:centerColor="#55F0C46A"
                android:endColor="#00F0C46A"
                android:startColor="#00F0C46A"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
