<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="160"
                android:centerColor="#10141C"
                android:endColor="#0A0C10"
                android:startColor="#0A0C10"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#00000000"
                android:endColor="#00000000"
                android:startColor="#12000000"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="120mm" />
            <gradient
                android:angle="90"
                android:endColor="#00000000"
                android:startColor="#1AE8A838"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="2mm" />
            <gradient
                android:angle="0"
                android:centerColor="#66F0C46A"
                android:endColor="#00F0C46A"
                android:startColor="#00F0C46A"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
