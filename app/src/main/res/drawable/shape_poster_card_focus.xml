<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/radius_poster_card" />
            <stroke
                android:width="@dimen/poster_focus_stroke"
                android:color="@color/ui_accent_bright" />
            <solid android:color="#66E8A838" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/radius_poster_card" />
            <stroke
                android:width="1mm"
                android:color="#33FFFFFF" />
            <solid android:color="#1C222D" />
        </shape>
    </item>
</selector>
