<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <inset
            android:insetBottom="1mm"
            android:insetLeft="1mm"
            android:insetRight="1mm"
            android:insetTop="1mm">
            <shape>
                <corners android:radius="20mm" />
                <solid android:color="@color/ui_accent" />
            </shape>
        </inset>
    </item>
    <item>
        <shape>
            <corners android:radius="20mm" />
            <solid android:color="#CCB8862A" />
        </shape>
    </item>
</selector>
