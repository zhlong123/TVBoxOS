<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <inset
            android:insetBottom="1mm"
            android:insetLeft="1mm"
            android:insetRight="1mm"
            android:insetTop="1mm">
            <shape android:shape="rectangle">
                <corners android:radius="10mm" />
                <stroke
                    android:width="1mm"
                    android:color="@color/ui_focus_ring_bright" />
                <solid android:color="#33E8A838" />
            </shape>
        </inset>
    </item>
    <item android:state_selected="true">
        <inset
            android:insetBottom="1mm"
            android:insetLeft="1mm"
            android:insetRight="1mm"
            android:insetTop="1mm">
            <shape android:shape="rectangle">
                <corners android:radius="10mm" />
                <stroke
                    android:width="1mm"
                    android:color="@color/ui_focus_ring_bright" />
                <solid android:color="#33E8A838" />
            </shape>
        </inset>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10mm" />
            <stroke
                android:width="1mm"
                android:color="@color/ui_stroke_subtle" />
            <solid android:color="#66151A22" />
        </shape>
    </item>
</selector>
