<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="14mm" />
            <stroke
                android:width="3mm"
                android:color="@color/ui_accent_bright" />
            <solid android:color="#40E8A838" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="14mm" />
            <stroke
                android:width="1mm"
                android:color="#22FFFFFF" />
            <solid android:color="#40151A22" />
        </shape>
    </item>
</selector>
