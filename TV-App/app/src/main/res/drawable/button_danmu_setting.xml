<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_6" />
            <solid android:color="@color/ui_accent_dim" />
            <stroke
                android:width="2.5mm"
                android:color="@color/ui_accent_bright" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/vs_6" />
            <solid android:color="@color/dialog_control_bg" />
            <stroke
                android:width="1mm"
                android:color="@color/dialog_control_stroke" />
        </shape>
    </item>
</selector>
