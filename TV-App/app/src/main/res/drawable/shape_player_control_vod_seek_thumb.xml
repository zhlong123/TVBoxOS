<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/ui_accent" />
            <stroke
                android:width="2dp"
                android:color="@color/ui_text_primary" />
            <size
                android:width="16dp"
                android:height="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/ui_accent_bright" />
            <stroke
                android:width="1.5dp"
                android:color="#E8F3EFE6" />
            <size
                android:width="14dp"
                android:height="14dp" />
        </shape>
    </item>
</selector>
