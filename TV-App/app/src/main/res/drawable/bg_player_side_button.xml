<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="@color/dialog_control_bg_focused" />
            <stroke
                android:width="2mm"
                android:color="@color/ui_stroke_focus" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/dialog_control_bg" />
            <stroke
                android:width="1mm"
                android:color="@color/dialog_control_stroke" />
        </shape>
    </item>
</selector>
