<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="#99E8A838" />
            <stroke
                android:width="2mm"
                android:color="@color/ui_stroke_focus" />
            <corners android:radius="8mm" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="#4DE8A838" />
            <stroke
                android:width="1mm"
                android:color="@color/ui_accent" />
            <corners android:radius="8mm" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8mm" />
        </shape>
    </item>
</selector>
