<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/vs_4"
    android:background="@drawable/shape_source_series_focus"
    android:defaultFocusHighlightEnabled="false"
    android:focusable="true"
    android:paddingLeft="@dimen/vs_4"
    android:paddingRight="@dimen/vs_4">

    <TextView
        android:id="@+id/tvSeries"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/vs_45"
        android:ellipsize="marquee"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:minWidth="@dimen/vs_100"
        android:paddingLeft="@dimen/vs_12"
        android:paddingRight="@dimen/vs_12"
        android:singleLine="true"
        android:textColor="@color/ui_text_primary"
        android:textSize="@dimen/ts_20" />
</FrameLayout>
