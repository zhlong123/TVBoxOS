<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_default"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingLeft="@dimen/vs_40"
    android:paddingTop="@dimen/vs_12"
    android:paddingRight="@dimen/vs_40"
    android:paddingBottom="@dimen/vs_20">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/vs_50"
        android:background="@drawable/bg_top_bar"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingLeft="@dimen/vs_24"
        android:paddingRight="@dimen/vs_24"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:singleLine="true"
            android:textColor="@color/ui_text_primary"
            android:textSize="@dimen/ts_28"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_4"
            android:ellipsize="middle"
            android:singleLine="true"
            android:textColor="@color/ui_text_secondary"
            android:textSize="@dimen/ts_20" />
    </LinearLayout>

    <com.owen.tvrecyclerview.widget.TvRecyclerView
        android:id="@+id/fileList"
        android:layout_width="@dimen/vs_0"
        android:layout_height="@dimen/vs_0"
        android:layout_marginTop="@dimen/vs_12"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:focusable="true"
        android:paddingBottom="@dimen/vs_10"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topLayout" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="当前目录为空"
        android:textColor="@color/ui_text_secondary"
        android:textSize="@dimen/ts_22"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topLayout" />
</androidx.constraintlayout.widget.ConstraintLayout>
