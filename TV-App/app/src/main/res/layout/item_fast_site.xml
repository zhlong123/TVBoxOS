<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:orientation="vertical"
    android:paddingTop="@dimen/vs_3"
    android:paddingBottom="@dimen/vs_3">

    <FrameLayout
        android:id="@+id/searchWordFrame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:defaultFocusHighlightEnabled="false"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:minHeight="@dimen/search_word_chip_height">

        <View
            android:id="@+id/searchWordBody"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_fast_site_body" />

        <TextView
            android:id="@+id/tvSearchWord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:duplicateParentState="false"
            android:ellipsize="marquee"
            android:focusable="false"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:marqueeRepeatLimit="marquee_forever"
            android:minHeight="@dimen/search_word_chip_height"
            android:paddingLeft="@dimen/vs_12"
            android:paddingTop="@dimen/vs_6"
            android:paddingRight="@dimen/vs_12"
            android:paddingBottom="@dimen/vs_6"
            android:singleLine="true"
            android:textColor="@color/ui_text_primary"
            android:textSize="@dimen/ts_20" />

        <View
            android:id="@+id/searchWordFocusRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_fast_site_focus"
            android:clickable="false"
            android:duplicateParentState="true"
            android:focusable="false" />
    </FrameLayout>
</LinearLayout>
