<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="@dimen/vs_520"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_danmu_setting_bg"
        android:orientation="vertical"
        android:paddingLeft="@dimen/vs_30"
        android:paddingTop="@dimen/vs_24"
        android:paddingRight="@dimen/vs_30"
        android:paddingBottom="@dimen/vs_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/vs_20"
            android:singleLine="true"
            android:text="弹幕设置"
            android:textColor="@color/dialog_text_primary"
            android:textSize="@dimen/ts_26"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8"
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5">

            <TextView
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:gravity="center_vertical|right"
                android:text="弹幕开关"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20" />

            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/trv_onoff"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_50"
                android:layout_marginStart="@dimen/vs_20"
                android:layout_weight="1"
                android:orientation="horizontal"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_10"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_10" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8"
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5">

            <TextView
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:gravity="center_vertical|right"
                android:text="弹幕颜色"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20" />

            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/trv_color"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_50"
                android:layout_marginStart="@dimen/vs_20"
                android:layout_weight="1"
                android:orientation="horizontal"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_10"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_10" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8"
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5">

            <TextView
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:gravity="center_vertical|right"
                android:text="弹幕速度"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20" />

            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/speed"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_50"
                android:layout_marginStart="@dimen/vs_20"
                android:layout_weight="1"
                android:orientation="horizontal"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_10"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_10" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8"
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5">

            <TextView
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:gravity="center_vertical|right"
                android:text="弹幕大小"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_50"
                android:layout_marginStart="@dimen/vs_20"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/sizeSub"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:layout_gravity="center"
                    android:background="@drawable/button_danmu_setting"
                    android:gravity="center"
                    android:focusable="true"
                    android:text="-"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_24" />

                <TextView
                    android:id="@+id/size"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_20" />

                <TextView
                    android:id="@+id/sizeAdd"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:layout_gravity="center"
                    android:background="@drawable/button_danmu_setting"
                    android:gravity="center"
                    android:focusable="true"
                    android:text="+"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_24" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8"
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5">

            <TextView
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:gravity="center_vertical|right"
                android:text="弹幕行数"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_50"
                android:layout_marginStart="@dimen/vs_20"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/lineSub"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:layout_gravity="center"
                    android:background="@drawable/button_danmu_setting"
                    android:gravity="center"
                    android:focusable="true"
                    android:text="-"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_24" />

                <TextView
                    android:id="@+id/line"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_20" />

                <TextView
                    android:id="@+id/lineAdd"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:layout_gravity="center"
                    android:background="@drawable/button_danmu_setting"
                    android:gravity="center"
                    android:focusable="true"
                    android:text="+"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_24" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5">

            <TextView
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:gravity="center_vertical|right"
                android:text="弹幕透明"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_20" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_50"
                android:layout_marginStart="@dimen/vs_20"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/alphaSub"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:layout_gravity="center"
                    android:background="@drawable/button_danmu_setting"
                    android:gravity="center"
                    android:focusable="true"
                    android:text="-"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_24" />

                <TextView
                    android:id="@+id/alpha"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_20" />

                <TextView
                    android:id="@+id/alphaAdd"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:layout_gravity="center"
                    android:background="@drawable/button_danmu_setting"
                    android:gravity="center"
                    android:focusable="true"
                    android:text="+"
                    android:textColor="@color/dialog_text_primary"
                    android:textSize="@dimen/ts_24" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
