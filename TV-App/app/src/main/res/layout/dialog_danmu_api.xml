<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="@dimen/vs_720"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_danmu_setting_bg"
        android:orientation="vertical"
        android:padding="@dimen/vs_30">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_20"
            android:text="弹幕地址"
            android:textColor="@color/dialog_text_primary"
            android:textSize="@dimen/ts_26" />

        <EditText
            android:id="@+id/input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_dialog_api_input"
            android:imeOptions="actionDone"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingLeft="@dimen/vs_2"
            android:paddingTop="@dimen/vs_10"
            android:paddingRight="@dimen/vs_2"
            android:paddingBottom="@dimen/vs_10"
            android:singleLine="true"
            android:textColor="@color/dialog_text_primary"
            android:textColorHint="@color/dialog_text_hint"
            android:textSize="@dimen/ts_24" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_20"
            android:gravity="right"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/inputDefault"
                android:layout_width="@dimen/vs_120"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/vs_10"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="@dimen/vs_10"
                android:text="默认"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_22" />

            <TextView
                android:id="@+id/inputSubmit"
                android:layout_width="@dimen/vs_120"
                android:layout_height="wrap_content"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="@dimen/vs_10"
                android:text="确定"
                android:textColor="@color/dialog_text_primary"
                android:textSize="@dimen/ts_22" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
